{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "alphacont-sibiu.vercel.app"
        }
      ],
      "destination": "https://alphacont.ro/ro",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "alphacont-sibiu.vercel.app"
        }
      ],
      "destination": "https://alphacont.ro/:path*",
      "permanent": true
    }
  ]
}
